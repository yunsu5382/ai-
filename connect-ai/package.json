{
  "name": "ai-mentor-yunsu",
  "displayName": "AI 맨토 윤수 — 1인 기업 워크스페이스",
  "description": "AI 멘토 윤수와 함께하는 1인 기업 워크스페이스. 나만의 AI 에이전트 팀과 제2의 두뇌가 한 곳에서 작동합니다.",
  "version": "2.89.157",
  "publisher": "yunsu",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wonseokjung/connect-ai"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Chat"
  ],
  "keywords": [
    "ai",
    "local",
    "ollama",
    "lmstudio",
    "gemma",
    "llama",
    "deepseek",
    "offline",
    "agent",
    "agent-team",
    "second-brain",
    "1인기업",
    "solopreneur",
    "code-generation",
    "connect-ai-lab",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "connect-ai-lab.newChat",
        "title": "Connect AI: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "connect-ai-lab.openSettings",
        "title": "Connect AI: ⚙️ 설정 열기"
      },
      {
        "command": "connect-ai-lab.exportChat",
        "title": "Connect AI: Export Chat as Markdown"
      },
      {
        "command": "connect-ai-lab.explainSelection",
        "title": "Connect AI: Explain Selected Code"
      },
      {
        "command": "connect-ai-lab.focusChat",
        "title": "Connect AI: Focus Chat Input"
      },
      {
        "command": "connect-ai-lab.showBrainNetwork",
        "title": "Connect AI: Show Brain Topology 🧠"
      },
      {
        "command": "connect-ai-lab.changeCompanyDir",
        "title": "Connect AI: 회사 폴더 변경 🏢"
      },
      {
        "command": "connect-ai-lab.connectCompanyRepo",
        "title": "Connect AI: 회사 GitHub 연결 ☁️"
      },
      {
        "command": "connect-ai-lab.connectGoogleCalendarWrite",
        "title": "Connect AI: Google Calendar 자동 일정 연결 📅"
      },
      {
        "command": "connectAiLab.tasks.refresh",
        "title": "할 일 새로고침",
        "category": "Connect AI",
        "icon": "$(refresh)"
      },
      {
        "command": "connectAiLab.tasks.markDone",
        "title": "완료 처리",
        "category": "Connect AI",
        "icon": "$(check)"
      },
      {
        "command": "connectAiLab.tasks.cancel",
        "title": "취소",
        "category": "Connect AI",
        "icon": "$(close)"
      },
      {
        "command": "connectAiLab.tasks.setPriority",
        "title": "우선순위 변경",
        "category": "Connect AI",
        "icon": "$(arrow-up)"
      },
      {
        "command": "connectAiLab.tasks.openTrackerJson",
        "title": "tracker.json 열기",
        "category": "Connect AI",
        "icon": "$(file-code)"
      },
      {
        "command": "connectAiLab.dailyBriefing.fireNow",
        "title": "지금 데일리 브리핑 발사",
        "category": "Connect AI",
        "icon": "$(megaphone)"
      },
      {
        "command": "connectAiLab.diagnoseConnection",
        "title": "🔍 LLM 연결 진단 (Ollama / LM Studio)",
        "category": "Connect AI",
        "icon": "$(pulse)"
      },
      {
        "command": "connectAiLab.youtube.refreshCommentQueue",
        "title": "YouTube 댓글 답장 큐 갱신",
        "category": "Connect AI",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "connectAiLab.developer.scaffoldProject",
        "title": "Developer: 새 프로젝트 만들기",
        "category": "Connect AI",
        "icon": "$(file-directory-create)"
      },
      {
        "command": "connectAiLab.skill.saveLast",
        "title": "방금 산출물 → 스킬로 저장 💎",
        "category": "Connect AI",
        "icon": "$(star)"
      },
      {
        "command": "connectAiLab.youtube.connectOAuth",
        "title": "YouTube OAuth 연결 (Analytics)",
        "category": "Connect AI",
        "icon": "$(plug)"
      },
      {
        "command": "connectAiLab.dashboard.open",
        "title": "우리 회사 (팀 + 오늘 + 채널)",
        "category": "Connect AI",
        "icon": "$(organization)"
      },
      {
        "command": "connectAiLab.apiConnections.open",
        "title": "외부 연결 (API 키 한 곳에서)",
        "category": "Connect AI",
        "icon": "$(plug)"
      },
      {
        "command": "connectAiLab.revenueDashboard.open",
        "title": "💰 매출 대시보드 (PayPal 실시간)",
        "category": "Connect AI",
        "icon": "$(graph-line)"
      }
    ],
    "keybindings": [
      {
        "command": "connect-ai-lab.focusChat",
        "key": "cmd+l",
        "mac": "cmd+l"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "connect-ai-lab.explainSelection",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ],
      "view/title": [
        {
          "command": "connectAiLab.tasks.refresh",
          "when": "view == connectAiLab.tasks",
          "group": "navigation"
        },
        {
          "command": "connectAiLab.tasks.openTrackerJson",
          "when": "view == connectAiLab.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "connectAiLab.tasks.markDone",
          "when": "view == connectAiLab.tasks && viewItem == openTask",
          "group": "inline@1"
        },
        {
          "command": "connectAiLab.tasks.cancel",
          "when": "view == connectAiLab.tasks && viewItem == openTask",
          "group": "inline@2"
        },
        {
          "command": "connectAiLab.tasks.setPriority",
          "when": "view == connectAiLab.tasks && viewItem == openTask",
          "group": "1_actions"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "connect-ai-lab-sidebar",
          "title": "AI 맨토 윤수",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "connect-ai-lab-sidebar": [
        {
          "type": "webview",
          "id": "connect-ai-lab-v2-view",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "AI 맨토 윤수",
      "properties": {
        "connectAiLab.ollamaUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "🤖 AI 서버 주소 (보통 자동으로 잡히니 건드리지 않아도 됩니다)"
        },
        "connectAiLab.pythonPath": {
          "type": "string",
          "default": "",
          "description": "🐍 Python 3 실행 명령/절대 경로 (비우면 자동 감지). 도구 실행 'exit 1' 또는 'Python was not found' 에러 시 여기에 직접 지정. 윈도우 예: 'py -3' 또는 'C:\\\\Python311\\\\python.exe'. 맥 예: '/opt/homebrew/bin/python3' 또는 'python3'. 변경 후 안티그래비티 재시작."
        },
        "connectAiLab.defaultModel": {
          "type": "string",
          "default": "",
          "description": "🧠 사용할 AI 모델 이름 (비워두면 설치된 모델 중 가장 작은 것이 자동 선택됨. 직접 지정 예: llama3.2:1b, gemma2:2b, qwen2.5:1.5b)"
        },
        "connectAiLab.requestTimeout": {
          "type": "number",
          "default": 300,
          "description": "⏱ AI 응답 대기 시간 (초, 기본 300초 = 5분)"
        },
        "connectAiLab.streamFirstTokenTimeoutSec": {
          "type": "number",
          "default": 240,
          "description": "🐢 모델 첫 토큰까지 기다리는 시간 (초). 저사양 머신은 모델 로드에 시간 걸려서 60초 안에 첫 응답 못 옴. 기본 240초(4분). 600초(10분)까지 늘려도 OK."
        },
        "connectAiLab.streamIdleTimeoutSec": {
          "type": "number",
          "default": 60,
          "description": "💤 첫 응답 이후 토큰 사이 최대 idle 시간 (초). 한 번 응답 시작하면 보통 빠르게 흘러서 60초면 충분. 모델 hang 감지용."
        },
        "connectAiLab.localBrainPath": {
          "type": "string",
          "default": "",
          "description": "📁 내 지식 폴더 경로 — 내 PC의 특정 폴더(예: 바탕화면/MyBrain)를 지정하면, 그 안의 .md 파일들이 AI의 지식이 됩니다. 비워두면 기본 폴더를 자동 생성합니다."
        },
        "connectAiLab.secondBrainRepo": {
          "type": "string",
          "default": "",
          "description": "🔗 두뇌 깃허브 저장소 URL — 내 지식을 클라우드에 백업하고 동기화할 깃허브 저장소 주소. (예: https://github.com/사용자/memory)"
        },
        "connectAiLab.companyRepo": {
          "type": "string",
          "default": "",
          "description": "🔗 회사 깃허브 저장소 URL — 회사 폴더를 두뇌와 별도 저장소로 백업할 때 사용. 회사 폴더가 두뇌 안 nested면(기본) 비워두세요(이미 두뇌 repo에 같이 들어감). 회사를 별도 위치(detached)로 분리한 경우에만 의미 있음. 명령 팔레트의 'Connect AI: 회사 GitHub 연결'로도 설정."
        },
        "connectAiLab.companyDir": {
          "type": "string",
          "default": "",
          "description": "👔 회사 폴더 경로 — 비워두면 두뇌 폴더 안 _company/에 자동 생성됩니다(시각적으로 분리·한 git repo). 절대 경로 또는 ~/로 시작하는 경로를 입력하면 두뇌와 완전히 분리된 별도 위치에 회사 폴더가 만들어집니다(예: 외주 공유용·다른 git repo). 명령 팔레트의 'Connect AI: 회사 폴더 변경'으로도 설정 가능."
        },
        "connectAiLab.assetsPath": {
          "type": "string",
          "default": "",
          "description": "🎨 (선택) LimeZu Modern Interiors 풀팩 폴더 — 사무실 뷰에 더 풍부한 캐릭터·인테리어를 쓰고 싶을 때만 지정합니다. 비워두면 vsix에 번들된 7개 캐릭터를 자동 사용합니다."
        },
        "connectAiLab.autoCycleEnabled": {
          "type": "boolean",
          "default": true,
          "description": "🤖 24시간 자율 사이클 — 켜두면 사용자가 30분 이상 자리를 비웠을 때 CEO가 회사 목표·각 에이전트 개인 목표를 검토해 자동으로 다음 한 스텝을 실행합니다. 에이전트 패널의 토글에서 같이 제어됩니다."
        },
        "connectAiLab.dailyBriefingTime": {
          "type": "string",
          "default": "09:00",
          "description": "📋 매일 자동 데일리 브리핑 발사 시각 (HH:MM, 24시간 형식). 비워두거나 'off'로 설정하면 자동 발사 안 함. 텔레그램으로 오늘 일정·할 일·어제 회사 활동 카드가 전송됩니다."
        },
        "connectAiLab.secretaryBridgeMode": {
          "type": "string",
          "enum": ["off", "output_only", "full"],
          "enumDescriptions": [
            "Off — 비서는 텔레그램에서만 활동. 사이드바는 CEO와 직접 대화 (현재 동작)",
            "출력만 — specialist 산출물 끝에 비서가 한 줄로 사장님께 정리 카드 추가",
            "풀 브릿지 — 사이드바 입력도 비서가 1차 수신 후 CEO에게 라우팅 또는 직접 응답"
          ],
          "default": "off",
          "description": "📱 비서 브릿지 모드 — 비서를 사람과 AI 회사 사이의 단일 통로로 만들지 결정. 차이를 직접 체감하면서 멀티에이전트 라우팅 패턴을 학습할 수 있어요."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vercel/ncc": "^0.38.4",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "jsdom": "^29.0.2"
  }
}
